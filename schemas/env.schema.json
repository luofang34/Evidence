{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://navigate.dev/schema/evidence/env.schema.json",
  "title": "EnvFingerprint",
  "description": "Build environment fingerprint for reproducibility verification",
  "type": "object",
  "required": [
    "profile",
    "rustc",
    "cargo",
    "git_sha",
    "git_branch",
    "git_dirty",
    "in_nix_shell",
    "tools",
    "nav_env"
  ],
  "properties": {
    "profile": {
      "type": "string",
      "enum": ["dev", "cert"],
      "description": "Build profile"
    },
    "rustc": {
      "type": "string",
      "description": "rustc --version output"
    },
    "cargo": {
      "type": "string",
      "description": "cargo --version output"
    },
    "git_sha": {
      "type": "string",
      "description": "Git commit SHA (40 hex chars or 'unknown')"
    },
    "git_branch": {
      "type": "string",
      "description": "Git branch name"
    },
    "git_dirty": {
      "type": "boolean",
      "description": "True if uncommitted changes present"
    },
    "in_nix_shell": {
      "type": "boolean",
      "description": "True if running inside nix-shell"
    },
    "tools": {
      "type": "object",
      "additionalProperties": { "type": "boolean" },
      "description": "Tool availability map (tool name -> present)"
    },
    "nav_env": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "NAV_* environment variables"
    },
    "llvm_version": {
      "type": "string",
      "description": "LLVM version from rustc -vV (optional)"
    },
    "host_os": {
      "type": "string",
      "enum": ["linux", "macos", "windows"],
      "description": "Host operating system"
    },
    "host_arch": {
      "type": "string",
      "enum": ["x86_64", "aarch64", "x86", "arm"],
      "description": "Host CPU architecture"
    },
    "libc_version": {
      "type": "string",
      "description": "libc version or type (glibc, musl, macOS, msvc)"
    }
  },
  "additionalProperties": false
}
